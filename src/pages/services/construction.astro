---
import ServiceLayout from '@/layouts/ServiceLayout.astro';
export const prerender = true;

const sections = [
  {
    heading: 'General Building Construction & Maintenance',
    items: [
      {
        title: 'New Builds',
        body: 'Constructing houses, offices, factories, schools, clinics, and other commercial and public facilities. We manage the full build process from foundation to final handover.',
      },
      {
        title: 'Renovations & Remodelling',
        body: 'Updating and transforming existing spaces - kitchens, bathrooms, offices, and entire buildings. We handle structural changes including adding or removing walls, partitions, and mezzanine floors.',
      },
      {
        title: 'Structural Work',
        body: 'Foundations, brickwork, concrete work, steel installations, and structural repairs. All structural work is carried out in compliance with SANS standards and relevant building regulations.',
      },
      {
        title: 'Finishes & Interiors',
        body: 'Painting, tiling, ceilings, plastering, drywalling, built-in cupboards, and complete internal fit-outs. We work with clients to achieve the finish and aesthetic they envision.',
      },
      {
        title: 'Specialised Trades',
        body: 'Electrical installations, plumbing, drainage, waterproofing, and carpentry - all carried out by qualified tradespeople.',
      },
      {
        title: 'External Works',
        body: 'Roofing, gutter installation, paving, landscaping, and retaining walls. We handle the full exterior of your building.',
      },
      {
        title: 'Maintenance & Repairs',
        body: 'Planned and reactive maintenance including roof repairs, plumbing emergencies, general upkeep, and facility management. Regular maintenance prevents costly breakdowns and extends the life of your building.',
      },
    ],
  },
  {
    heading: 'Road Construction, Maintenance & Safety Management',
    items: [
      {
        title: 'Surface Treatment',
        body: 'Asphalt paving, resurfacing, and road surface treatments to extend road life and improve safety for road users.',
      },
      {
        title: 'Civil Works',
        body: 'General road construction including tar road maintenance, repair, and new road development for municipalities and private clients.',
      },
      {
        title: 'Preventive Maintenance',
        body: 'Routine road inspections, crack sealing, and pothole filling to address issues before they become costly failures.',
      },
      {
        title: 'Drainage & Vegetation Control',
        body: 'Maintaining proper stormwater drainage systems and managing roadside vegetation to prevent road damage and improve visibility.',
      },
      {
        title: 'Work Zone Safety',
        body: 'Deploying traffic management equipment including cones, barrels, and concrete median barriers to safely separate road users from active work zones.',
      },
      {
        title: 'Traffic Control',
        body: 'Implementing flagging operations, temporary speed limit signage, and traffic flow management to guide road users safely around construction sites.',
      },
      {
        title: 'Road Safety Audits',
        body: 'Conducting formal road safety audits (RSA) and site inspections to identify and remediate potential hazards and blackspots before they cause incidents.',
      },
    ],
  },
];
---

<ServiceLayout
  title='Construction & Civil Engineering'
  description='General building construction, road construction, road maintenance and road safety management services in Pretoria and Gauteng - Phehlwana Group Investments.'
  label='Construction & Civil Engineering'
  subtitle='From new builds and renovations to road construction and safety management - delivered to CIDB standards.'
  image='/images/services/service-construction.png'
  imageAlt='Phehlwana Group construction team working on a building project in Pretoria'
  serviceParam='Construction & Civil Engineering'
>
  {
    sections.map((section) => (
      <div class='mb-12' data-animate>
        <h2 class='text-xl font-bold text-foreground mb-6 pb-3 border-b border-border'>
          {section.heading}
        </h2>
        <div class='grid sm:grid-cols-2 gap-4'>
          {section.items.map((item) => (
            <div class='bg-card border border-border rounded-xl p-5'>
              <h3 class='text-sm font-semibold text-foreground mb-2 flex items-center gap-2'>
                <span class='size-1.5 rounded-full bg-primary shrink-0' />
                {item.title}
              </h3>
              <p class='text-sm text-muted-foreground leading-relaxed'>
                {item.body}
              </p>
            </div>
          ))}
        </div>
      </div>
    ))
  }
</ServiceLayout>
