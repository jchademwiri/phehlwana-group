---
/**
 * PageHeader — reusable interior page header
 *
 * Props:
 *   label?    — small eyebrow text above the title (e.g. "Our Work")
 *   title     — main h1
 *   subtitle? — supporting paragraph
 *   breadcrumbs? — array of { label, href } — last item is current page (no href needed)
 */

interface Breadcrumb {
    label: string;
    href?: string;
}

interface Props {
    label?: string;
    title: string;
    subtitle?: string;
    breadcrumbs?: Breadcrumb[];
}

const { label, title, subtitle, breadcrumbs } = Astro.props;
---

<section
    class='bg-accent/40 border-b border-border pt-28 pb-12 lg:pt-36 lg:pb-16'
>
    <div class='container mx-auto px-4'>
        <!-- Breadcrumb -->
        {
            breadcrumbs && breadcrumbs.length > 0 && (
                <nav aria-label='Breadcrumb' class='mb-5'>
                    <ol class='flex items-center flex-wrap gap-1.5 text-xs text-muted-foreground'>
                        {breadcrumbs.map((crumb, i) => (
                            <>
                                {i > 0 && (
                                    <li aria-hidden='true'>
                                        <svg
                                            xmlns='http://www.w3.org/2000/svg'
                                            class='size-3'
                                            viewBox='0 0 24 24'
                                            fill='none'
                                            stroke='currentColor'
                                            stroke-width='2.5'
                                            stroke-linecap='round'
                                            stroke-linejoin='round'
                                        >
                                            <path d='m9 18 6-6-6-6' />
                                        </svg>
                                    </li>
                                )}
                                <li>
                                    {crumb.href ? (
                                        <a
                                            href={crumb.href}
                                            class='hover:text-foreground transition-colors'
                                        >
                                            {crumb.label}
                                        </a>
                                    ) : (
                                        <span
                                            class='text-foreground font-medium'
                                            aria-current='page'
                                        >
                                            {crumb.label}
                                        </span>
                                    )}
                                </li>
                            </>
                        ))}
                    </ol>
                </nav>
            )
        }

        <!-- Label -->
        {
            label && (
                <p class='text-sm font-semibold text-primary uppercase tracking-widest mb-2'>
                    {label}
                </p>
            )
        }

        <!-- Title -->
        <h1 class='text-4xl font-bold text-foreground mb-3'>{title}</h1>

        <!-- Subtitle -->
        {
            subtitle && (
                <p class='text-muted-foreground max-w-xl text-base leading-relaxed'>
                    {subtitle}
                </p>
            )
        }

        <!-- Slot for extra content (e.g. filter buttons, meta pills) -->
        <slot />
    </div>
</section>
